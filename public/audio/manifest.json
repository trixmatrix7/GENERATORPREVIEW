{
  "version": "1.0.0",
  "audioDir": "/audio",
  "formats": [
    "ogg",
    "mp3"
  ],
  "initialVolume": 0.6,
  "initialMuted": false,
  "events": [
    {
      "id": "spin-start",
      "name": "Spin Start",
      "description": "Short whoosh sound when reels begin spinning.",
      "trigger": "spin button click",
      "loop": false,
      "exclusive": false,
      "volume": 0.5,
      "priority": "high",
      "src": [
        "/audio/spin-start.ogg",
        "/audio/spin-start.mp3"
      ]
    },
    {
      "id": "reel-stop",
      "name": "Reel Stop",
      "description": "Thud/click when each reel lands. Played 5 times per spin with stagger.",
      "trigger": "each reel landing",
      "loop": false,
      "exclusive": false,
      "volume": 0.6,
      "priority": "high",
      "src": [
        "/audio/reel-stop.ogg",
        "/audio/reel-stop.mp3"
      ]
    },
    {
      "id": "win-small",
      "name": "Small Win",
      "description": "Brief chime for wins under 2× bet.",
      "trigger": "win < 2× bet",
      "loop": false,
      "exclusive": false,
      "volume": 0.7,
      "priority": "medium",
      "src": [
        "/audio/win-small.ogg",
        "/audio/win-small.mp3"
      ]
    },
    {
      "id": "win-big",
      "name": "Big Win",
      "description": "Escalating fanfare for wins 10×–50× bet.",
      "trigger": "win 10×–50× bet",
      "loop": false,
      "exclusive": false,
      "volume": 0.85,
      "priority": "high",
      "src": [
        "/audio/win-big.ogg",
        "/audio/win-big.mp3"
      ]
    },
    {
      "id": "win-mega",
      "name": "Mega Win",
      "description": "Epic celebration for wins 50×+ bet.",
      "trigger": "win >= 50× bet",
      "loop": false,
      "exclusive": false,
      "volume": 0.95,
      "priority": "high",
      "src": [
        "/audio/win-mega.ogg",
        "/audio/win-mega.mp3"
      ]
    },
    {
      "id": "scatter-land",
      "name": "Scatter Land",
      "description": "Distinctive sound when a scatter symbol becomes visible.",
      "trigger": "scatter visible on reel stop",
      "loop": false,
      "exclusive": false,
      "volume": 0.7,
      "priority": "high",
      "src": [
        "/audio/scatter-land.ogg",
        "/audio/scatter-land.mp3"
      ]
    },
    {
      "id": "free-spin-trigger",
      "name": "Free Spin Trigger",
      "description": "Triumphant sound when 3+ scatters trigger the bonus.",
      "trigger": "scatterCount >= 3",
      "loop": false,
      "exclusive": false,
      "volume": 0.9,
      "priority": "high",
      "src": [
        "/audio/free-spin-trigger.ogg",
        "/audio/free-spin-trigger.mp3"
      ]
    },
    {
      "id": "near-miss-tease",
      "name": "Near-Miss Tease",
      "description": "Rising tension tone when a reel enters its near-miss slowdown phase.",
      "trigger": "reel entering near-miss deceleration",
      "loop": false,
      "exclusive": false,
      "volume": 0.7,
      "priority": "high",
      "src": [
        "/audio/near-miss-tease.ogg",
        "/audio/near-miss-tease.mp3"
      ]
    },
    {
      "id": "win-normal",
      "name": "Normal Win",
      "description": "Mid-tier chime for wins 2×–10× bet. Bridges small and big win stings.",
      "trigger": "win 2×-10× bet",
      "loop": false,
      "exclusive": false,
      "volume": 0.7,
      "priority": "medium",
      "src": [
        "/audio/win-normal.ogg",
        "/audio/win-normal.mp3"
      ]
    },
    {
      "id": "reel-spin-loop",
      "name": "Reel Spin Loop",
      "description": "Looping mechanical whir while reels are in motion. Stops when all reels land.",
      "trigger": "reels spinning",
      "loop": true,
      "exclusive": false,
      "volume": 0.7,
      "priority": "low",
      "src": [
        "/audio/reel-spin-loop.ogg",
        "/audio/reel-spin-loop.mp3"
      ]
    },
    {
      "id": "coin-chime",
      "name": "Coin Chime",
      "description": "Short coin impact accent used during big+ win celebrations.",
      "trigger": "big/mega win celebration timeline",
      "loop": false,
      "exclusive": false,
      "volume": 0.7,
      "priority": "medium",
      "src": [
        "/audio/coin-chime.ogg",
        "/audio/coin-chime.mp3"
      ]
    },
    {
      "id": "ambient-music",
      "name": "Background Music",
      "description": "Looping ambient music during gameplay. Separate tracks for base and bonus.",
      "trigger": "game load",
      "loop": true,
      "exclusive": true,
      "volume": 0.35,
      "priority": "low",
      "src": [
        "/audio/ambient-music.ogg",
        "/audio/ambient-music.mp3"
      ]
    }
  ]
}
